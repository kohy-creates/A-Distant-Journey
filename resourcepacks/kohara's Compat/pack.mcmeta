{
  "pack": {
    "pack_format": 15,
    "description": "Extra compatibility between mods in 'A Distant Journey'"
  },
  "filter": {
    "block": [
      {
        "namespace": "^afterimages$",
        "path": "^afterimages/entities/.*$"
      },
      {
        "namespace": "^minecraft$",
        "path": "^sounds/blocks/.*.json$"
      }
    ]
  }
}
