{
	"pack": {
		"pack_format": 48,
		"description": "kohara's different tweaks"
	},
	"filter": {
		"block": [
			{
				"path": "^advancements/recipes/.*$"
			},
			{
				"namespace": "^(?!(adj|born_in_chaos_v1|true_ending|unusualend|phantasm|twilightforest|minecraft|wither_rework)$).+",
				"path": "^advancements/.*$"
			},
			{
				"namespace": "^trofers$",
				"path": "^trofers/.*$"
			},
			{
				"namespace": "^gateways$",
				"path": "^gateways/.*$"
			}
		]
	}
}
