{
	"pack": {
		"pack_format": 48,
		"description": "kohara's different tweaks"
	},
	"filter": {
		"block": [
			{
				"path": "^advancements/recipes.*$"
			},
			{
				"namespace": "^(?!adj$|born_in_chaos_v1$|true_ending$|unusualend$|twilightforest$)",
				"path": "^advancements/.*$"
			},
			{
				"namespace": "^(evilcraft$|croptopia$|travelersbackpack$)",
				"path": "^loot_modifiers/.*$"
			},
			{
				"namespace": "^travelersbackpack$",
				"path": "^loot_tables/blocks/.*$"
			}
		]
	}
}
